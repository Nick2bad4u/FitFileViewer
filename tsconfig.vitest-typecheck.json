{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "isolatedDeclarations": false,
        "noEmit": true,
        "tsBuildInfoFile": "./.cache/tsbuildinfo/tsconfig.vitest-typecheck.tsbuildinfo"
    },
    "exclude": [
        ".cache/**",
        "coverage/**",
        "electron-app/coverage/**",
        "electron-app/dist/**",
        "node_modules/**"
    ],
    "extends": "./tsconfig.electron-app.json",
    "include": [
        "electron-app/index.d.ts",
        "electron-app/tests/**/*.test-d.ts",
        "electron-app/tests/**/*.test-d.mts",
        "electron-app/tests/**/*.test-d.cts",
        "electron-app/tests/**/*.spec-d.ts",
        "electron-app/tests/**/*.spec-d.mts",
        "electron-app/tests/**/*.spec-d.cts"
    ]
}
