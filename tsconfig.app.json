{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "allowUmdGlobalAccess": false,
        "allowUnreachableCode": false,
        "allowUnusedLabels": false,
        "declaration": true,
        "declarationDir": "./types",
        "declarationMap": false,
        "disableSizeLimit": true,
        "incremental": true,
        "jsx": "react-jsx",
        "lib": [
            "DOM.Iterable",
            "DOM",
            "ES2015",
            "ES2016",
            "ES2017",
            "ES2018",
            "ES2019",
            "ES2020",
            "ES2021",
            "ES2022",
            "ES2023",
            "ES6",
            "ES7",
            "ESNext"
        ],
        "noCheck": false,
        "noImplicitUseStrict": false,
        "paths": {
            "@shared/*": [
                "./electron-app/shared/*"
            ]
        },
        "pretty": true,
        "skipDefaultLibCheck": true,
        "sourceMap": true,
        "strictBindCallApply": true,
        "strictBuiltinIteratorReturn": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
    },
    "exclude": [
        "**/dist-electron",
        "**/dist-electron/**",
        "**/dist",
        "**/libs",
        "**/dist/**",
        "**/node_modules",
        "**/node_modules/@types/**",
        "**/node_modules/@typescript-eslint/**",
        "**/node_modules/**",
        "**/node_modules/typescript/**",
        "coverage",
        "dist-electron",
        "dist",
        "dist-shared",
        "**/dist-shared/**",
        "node_modules",
        "node_modules/**/*",
        "out",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/tests/**",
        "**/assets/**"
    ],
    "extends": "./tsconfig.app.base.json",
    "include": [
        "electron-app/*.ts",
        "electron-app/**/*.js",
        "global.d.ts",
        "electron-app/shared/**/*.ts",
        "electron-app/main/**/*.ts",
        "electron-app/preload/**/*.ts",
        "electron-app/renderer/**/*.ts",
        "electron-app/ui/**/*.ts",
        "electron-app/windowStateUtils.ts",
        "electron-app/utils.ts",
        "electron-app/utils/**/*.ts",
        "vite/client"
    ],
    "typeAcquisition": {
        "enable": true
    }
}
