{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": false,
        "allowSyntheticDefaultImports": true,
        "alwaysStrict": true,
        "checkJs": false,
        "declaration": false,
        "declarationMap": false,
        "emitDeclarationOnly": false,
        "esModuleInterop": true,
        "exactOptionalPropertyTypes": true,
        "forceConsistentCasingInFileNames": true,
        "incremental": false,
        "isolatedDeclarations": false,
        "isolatedModules": true,
        "lib": ["DOM", "DOM.Iterable", "ES2024"],
        "module": "ESNext",
        "moduleDetection": "auto",
        "moduleResolution": "bundler",
        "noEmit": false,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noPropertyAccessFromIndexSignature": true,
        "noUncheckedIndexedAccess": true,
        "noUncheckedSideEffectImports": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "resolveJsonModule": true,
        "resolvePackageJsonExports": true,
        "resolvePackageJsonImports": true,
        "skipLibCheck": true,
        "sourceMap": false,
        "strict": true,
        "target": "ES2024",
        "types": ["electron", "node"],
        "useDefineForClassFields": true,
        "useUnknownInCatchVariables": true
    },
    "files": [
        "utils/config/constants.ts",
        "utils/config/index.ts",
        "utils/state/core/stateManagerDefaults.ts",
        "utils/state/core/stateManagerHistory.ts",
        "utils/state/core/stateManagerPathUtils.ts",
        "utils/state/core/stateManagerReset.ts",
        "utils/state/core/stateManager.ts",
        "utils/state/domain/settingsStateSchema.ts",
        "utils/formatting/converters/convertArrayBufferToBase64.ts",
        "utils/formatting/converters/convertDistanceUnits.ts",
        "utils/formatting/converters/convertMpsToKmh.ts",
        "utils/formatting/converters/convertMpsToMph.ts",
        "utils/formatting/converters/convertTemperatureUnits.ts",
        "utils/formatting/converters/convertTimeUnits.ts",
        "utils/formatting/display/formatAntNames.ts",
        "utils/formatting/display/formatCapitalize.ts",
        "utils/formatting/display/formatChartFields.ts",
        "utils/formatting/display/formatSpeedTooltip.ts",
        "utils/formatting/formatters/formatDistance.ts",
        "utils/formatting/formatters/formatDuration.ts",
        "utils/formatting/formatters/formatHeight.ts",
        "utils/formatting/formatters/formatManufacturer.ts",
        "utils/formatting/formatters/formatProduct.ts",
        "utils/formatting/formatters/formatSensorName.ts",
        "utils/formatting/formatters/formatUtils.ts",
        "utils/formatting/formatters/formatWeight.ts",
        "utils/logging/getErrorInfo.ts",
        "utils/logging/logWithLevel.ts",
        "utils/logging/rendererLogger.ts",
        "utils/logging/index.ts",
        "utils/errors/errorHandling.ts",
        "utils/errors/index.ts",
        "utils/async/pLimitCompat.ts",
        "utils/net/networkUtils.ts",
        "utils/docs/documentationStandards.ts",
        "utils/performance/index.ts",
        "utils/performance/performanceMonitor.ts",
        "utils/storage/storageUtils.ts",
        "utils/files/sanitizeFilename.ts",
        "utils/dom/domHelpers.ts",
        "utils/dom/escapeHtml.ts",
        "utils/dom/sanitizeCssColorToken.ts",
        "utils/dom/sanitizeHtmlAllowlist.ts"
    ]
}
