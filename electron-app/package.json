        "assets/",
        "dist/",
        "elevProfile.css",
        "global.d.ts",
        "icons/",
        "index.html",
        "package.json",
        "style.css"
    ],
    "scripts": {
        "prebuild": "npm run build:runtime-ts",
        "build": "electron-builder",
        "build:dev": "cross-env NODE_ENV=development electron-builder",
        "build:dev:all": "cross-env NODE_ENV=development electron-builder -l",
        "build:dev:package": "cross-env NODE_ENV=development electron-builder --dir",
        "build:dev:package:all": "cross-env NODE_ENV=development electron-builder -l --dir",
        "build:dev:package:prod": "cross-env NODE_ENV=production electron-builder --dir",
        "build:dev:package:prod:all": "cross-env NODE_ENV=production electron-builder -l --dir",
        "build:dev:package:prod:all:zip": "cross-env NODE_ENV=production electron-builder -l --dir --win --x64 --ia32 --mac --linux --zip",
        "build:prod": "cross-env NODE_ENV=production electron-builder",
        "build:renderer": "npm --prefix .. run build:renderer",
        "build:runtime-ts": "npm --prefix .. run build:runtime-ts",
        "build:win7": "node ./scripts/build-win7.mjs",
        "build-all": "electron-builder -mwl",
        "format": "npm --prefix .. run format",
        "format:check": "npm --prefix .. run format:check",
        "lint": "npm --prefix .. run lint:electron-app",
        "lint:all": "npm --prefix .. run lint",
        "lint:all:fix": "npm --prefix .. run lint:fix",
        "lint:css": "npm --prefix .. run lint:css",
        "lint:css:fix": "npm --prefix .. run lint:css:fix",
        "lint:fix": "npm --prefix .. run lint:electron-app:fix",
        "prepackage": "npm run build:runtime-ts",
        "package": "electron-builder --dir",
        "prettier": "npm --prefix .. run prettier",
        "prettier:fix": "npm --prefix .. run prettier:fix",
        "prestart": "npm run build:runtime-ts",
        "start": "electron . --inspect=9229 --remote-debugging-port=9222",
        "prestart-prod": "npm run build:runtime-ts",
        "start-prod": "cross-env ELECTRON_IS_DEV=0 electron .",
        "test": "npm --prefix .. test",
        "test:changed": "npm --prefix .. run test:changed",
        "test:ci": "npm --prefix .. run test:ci",
        "test:coverage": "npm --prefix .. run test:coverage",
        "test:coverage-changed": "npm --prefix .. run test:coverage-changed",
        "test:e2e": "npm --prefix .. run test:playwright",
        "test:integration": "npm --prefix .. run test:integration",
        "test:playwright": "npm --prefix .. run test:playwright",
        "test:tabs": "npm --prefix .. run test:tabs",
        "test:unit": "npm --prefix .. run test:unit",
        "test:watch": "npm --prefix .. run test:watch",
        "test:watch-changed": "npm --prefix .. run test:watch-changed",
        "tests:convert-to-ts": "node ./scripts/convert-tests-to-ts.mjs",
        "typecheck": "tsc --project .\\tsconfig.json --noEmit",
        "types:build": "tsc --project .\\tsconfig.json --declaration --emitDeclarationOnly --declarationMap false --outDir ./types",
        "update-deps": "npm --workspace-root run update-deps"
    },
    "overrides": {
        "jsonc-eslint-parser": "$jsonc-eslint-parser"
    },
