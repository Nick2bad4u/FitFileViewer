        "build:dev:package:prod:all:zip": "cross-env NODE_ENV=production electron-builder -l --dir --win --x64 --ia32 --mac --linux --zip",
        "build:prod": "cross-env NODE_ENV=production electron-builder",
        "build:runtime-ts": "tsc --project .\\tsconfig.runtime.json && node ./scripts/format-runtime-output.mjs",
        "build:win7": "node ./scripts/build-win7.mjs",
        "build-all": "electron-builder -mwl",
        "changelog": "powershell -ExecutionPolicy Bypass -File .\\Update-ChangeLogs.ps1",
        "changelog:all": "powershell -ExecutionPolicy Bypass -File .\\Update-ChangeLogs.ps1",
        "clean-releases": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1",
        "clean-releases:1": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 1",
        "clean-releases:10": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 10",
        "clean-releases:2": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 2",
        "clean-releases:3": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 3",
        "clean-releases:4": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 4",
        "clean-releases:5": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 5",
        "clean-releases:6": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 6",
        "clean-releases:7": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 7",
        "clean-releases:8": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 8",
        "clean-releases:9": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 9",
        "clean-releases:all": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags -keepLast 1000",
        "clean-releases-tags": "powershell -ExecutionPolicy Bypass -File ../.github/Clean-Releases.ps1 -deleteTags",
        "cliff": "powershell -ExecutionPolicy Bypass -File ../.github/Update-ChangeLogs.ps1",
        "cliff-all": "powershell -ExecutionPolicy Bypass -File ../.github/Update-ChangeLogs.ps1",
        "format": "npx prettier \"*.{js,md,css,html}\" -c ..\\.prettierrc --write && npx prettier \"utils\\*.{js,md,css,html}\" -c ..\\.prettierrc --write",
        "format:check": "npx prettier \"*.{js,md,css,html}\" -c ..\\.prettierrc --check && npx prettier \"utils\\*.{js,md,css,html}\" -c ..\\.prettierrc --check",
        "format:lint": "npx eslint --ext .js,.jsx,.ts,.tsx --fix .",
        "format:lint:check": "npx eslint --ext .js,.jsx,.ts,.tsx .",
        "format:lint:check:fix": "npx eslint --ext .js,.jsx,.ts,.tsx --fix .",
        "format:lint:check:fix:all": "npx eslint --ext .js,.jsx,.ts,.tsx --fix --max-warnings 0 .",
        "format:lint:fix": "npx eslint --ext .js,.jsx,.ts,.tsx --fix .",
        "lint": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache --fix && npm run typecheck && npm run prettier:fix",
        "lint:all": "npm run lint:css && npx eslint --ext .js,.jsx,.ts,.tsx --max-warnings 0 . && npm run typecheck && npm run prettier",
        "lint:all:fix": "npm run lint:css:fix && npm run format:lint:check:fix:all && npm run typecheck && npm run prettier:fix",
        "lint:css": "npx stylelint \"**/*.css\" --config stylelint.config.mjs",
        "lint:css:fix": "npx stylelint \"**/*.css\" --config stylelint.config.mjs --fix",
        "lint:fix": "npm run lint",
        "prepackage": "npm run build:runtime-ts",
        "package": "electron-builder --dir",
        "prettier": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "prettier:fix": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "prestart": "npm run build:runtime-ts",
        "start": "electron . --inspect=9229 --remote-debugging-port=9222",
        "prestart-prod": "npm run build:runtime-ts",
        "start-prod": "cross-env ELECTRON_IS_DEV=0 electron .",
        "test": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --run --reporter=dot --silent --maxWorkers 1",
        "test:changed": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:ci": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --run --coverage --reporter=dot --silent --maxWorkers 1",
        "test:coverage": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --coverage --run --reporter=dot --silent --maxWorkers 1",
        "test:coverage:enhanced": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.enhanced.js --coverage --run --reporter=dot --silent --maxWorkers 1",
        "test:coverage-changed": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --coverage --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:e2e": "jest --testPathPattern=e2e",
        "test:enhanced": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.enhanced.js --run --reporter=dot --silent --maxWorkers 1",
        "test:integration": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --run tests/integration --maxWorkers 1",
        "test:jest": "jest",
        "test:tabs": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --run --reporter=verbose tests/unit/tabs --maxWorkers 1",
        "test:unit": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --run tests/unit --maxWorkers 1",
        "test:watch": "vitest --watch",
        "test:watch-changed": "vitest --watch --changed",
        "tests:convert-to-ts": "node ./scripts/convert-tests-to-ts.mjs",
        "typecheck": "tsc --project .\\tsconfig.json --noEmit",
        "types:build": "tsc --project .\\tsconfig.json --declaration --emitDeclarationOnly --declarationMap false --outDir ./types",
        "update-changelog": "powershell -ExecutionPolicy Bypass -File .\\Update-ChangeLogs.ps1",
        "update-changelog:all": "powershell -ExecutionPolicy Bypass -File .\\Update-ChangeLogs.ps1",
        "update-changelog:latest": "powershell -ExecutionPolicy Bypass -File .\\Update-ChangeLogs.ps1",
        "update-deps": "npx ncu -i --install never && npm install --force && cd ../docusaurus && npx ncu -i --install never && npm install --force && cd ../electron-app"
    },
