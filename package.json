{
    "name": "fitfileviewer-root",
    "private": true,
    "description": "Root workspace tooling for FitFileViewer.",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com>",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "main": "package.json",
    "workspaces": [
        "electron-app",
        "docusaurus"
    ],
    "scripts": {
        "build": "npm --workspace electron-app run build",
        "build:all": "npm --workspace electron-app run build-all",
        "build:dev": "npm --workspace electron-app run build:dev",
        "build:dev:package": "npm --workspace electron-app run build:dev:package",
        "build:prod": "npm --workspace electron-app run build:prod",
        "build:renderer": "npm --workspace electron-app run build:renderer",
        "build:runtime-ts": "npm --workspace electron-app run build:runtime-ts",
        "build:win7": "npm --workspace electron-app run build:win7",
        "changelog": "powershell -ExecutionPolicy Bypass -File ./.github/Update-ChangeLogs.ps1",
        "changelog:all": "powershell -ExecutionPolicy Bypass -File ./.github/Update-ChangeLogs.ps1",
        "docs:build": "npm --workspace docusaurus run build",
        "docs:start": "npm --workspace docusaurus start",
        "docs:typecheck": "npm --workspace docusaurus run typecheck",
        "format": "npm run prettier:fix",
        "format:check": "npm run prettier",
        "lint": "npm run lint:root && npm run lint:electron-app && npm run lint:docusaurus",
        "lint:all": "npm run lint",
        "lint:all:fix": "npm run lint:fix",
        "lint:css": "stylelint \"electron-app/**/*.css\" --config stylelint.config.mjs --quiet",
        "lint:css:fix": "stylelint \"electron-app/**/*.css\" --config stylelint.config.mjs --fix",
        "lint:docusaurus": "npm --workspace docusaurus run lint",
        "lint:docusaurus:content": "npm --workspace docusaurus run lint:content",
        "lint:docusaurus:fix": "npm --workspace docusaurus run lint:fix",
        "lint:electron-app": "npm --workspace electron-app run lint",
        "lint:electron-app:fix": "npm --workspace electron-app run lint:fix",
        "lint:fix": "npm run lint:root:fix && npm run lint:electron-app:fix && npm run lint:docusaurus:fix",
        "lint:root": "npx eslint --cache --cache-strategy content --cache-location electron-app/.cache/.eslintcache-root . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "lint:root:check": "npx eslint --cache --cache-strategy content --cache-location electron-app/.cache/.eslintcache-root . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "lint:root:fix": "npx eslint --cache --cache-strategy content --cache-location electron-app/.cache/.eslintcache-root --fix . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "package": "npm --workspace electron-app run package",
        "prettier": "prettier package.json electron-app/package.json docusaurus/package.json prettier.config.mjs stylelint.config.mjs .remarkrc.mjs eslint.config.mjs --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "prettier:fix": "prettier package.json electron-app/package.json docusaurus/package.json prettier.config.mjs stylelint.config.mjs .remarkrc.mjs eslint.config.mjs --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "start": "npm --workspace electron-app start",
        "start:prod": "npm --workspace electron-app run start-prod",
        "test": "npm --workspace electron-app test",
        "test:changed": "npm --workspace electron-app run test:changed",
        "test:coverage": "npm --workspace electron-app run test:coverage",
        "test:e2e": "npm --workspace electron-app run test:e2e",
        "test:playwright": "npm --workspace electron-app run test:playwright",
        "test:unit": "npm --workspace electron-app run test:unit",
        "test:watch": "npm --workspace electron-app run test:watch",
        "typecheck": "npm --workspace electron-app run typecheck",
        "update-deps": "npx npm-check-updates -i --workspaces --root --install never && npm install"
    },
    "devDependencies": {
        "eslint-config-nick2bad4u": "^1.1.0",
        "git-cliff": "^2.13.1",
        "prettier": "^3.8.3",
        "prettier-config-nick2bad4u": "^1.0.13",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.0.2",
        "remark-lint-check-toc": "^1.0.0",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.0.5",
        "stylelint": "^17.12.0",
        "stylelint-config-nick2bad4u": "^1.0.12"
    },
    "packageManager": "npm@11.15.0",
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=7.0.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "npm",
            "version": ">=7.0.0",
            "onFail": "warn"
        },
        "runtime": {
            "name": "node",
            "onFail": "warn",
            "version": ">=16.0.0"
        }
    }
}
