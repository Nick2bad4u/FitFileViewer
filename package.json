{
    "name": "fitfileviewer-root",
    "private": true,
    "description": "Root workspace tooling for FitFileViewer.",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com>",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "main": "package.json",
    "workspaces": [
        "electron-app",
        "docusaurus"
    ],
    "scripts": {
        "build": "npm --workspace electron-app run build",
        "build:all": "npm --workspace electron-app run build-all",
        "build:dev": "npm --workspace electron-app run build:dev",
        "build:dev:all": "npm --workspace electron-app run build:dev:all",
        "build:dev:package": "npm --workspace electron-app run build:dev:package",
        "build:dev:package:all": "npm --workspace electron-app run build:dev:package:all",
        "build:dev:package:prod": "npm --workspace electron-app run build:dev:package:prod",
        "build:dev:package:prod:all": "npm --workspace electron-app run build:dev:package:prod:all",
        "build:dev:package:prod:all:zip": "npm --workspace electron-app run build:dev:package:prod:all:zip",
        "build:prod": "npm --workspace electron-app run build:prod",
        "build:renderer": "vite build --config vite.renderer.config.mjs",
        "build:runtime-ts": "node scripts/clean-runtime-dist.mjs && tsc --project electron-app\\tsconfig.runtime.json && node scripts/bundle-preload.mjs && npm run build:renderer && node scripts/format-runtime-output.mjs && node scripts/prepare-runtime-dist.mjs",
        "build:win7": "node scripts/build-win7.mjs",
        "build-all": "npm run build:all",
        "changelog": "powershell -ExecutionPolicy Bypass -File ./.github/Update-ChangeLogs.ps1",
        "changelog:all": "powershell -ExecutionPolicy Bypass -File ./.github/Update-ChangeLogs.ps1",
        "clean-releases": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1",
        "clean-releases:1": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 1",
        "clean-releases:10": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 10",
        "clean-releases:2": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 2",
        "clean-releases:3": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 3",
        "clean-releases:4": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 4",
        "clean-releases:5": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 5",
        "clean-releases:6": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 6",
        "clean-releases:7": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 7",
        "clean-releases:8": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 8",
        "clean-releases:9": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 9",
        "clean-releases:all": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 1000",
        "clean-releases-tags": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags",
        "cliff": "npm run changelog",
        "cliff-all": "npm run changelog:all",
        "coverage:analyze": "node scripts/analyze-coverage.mjs",
        "coverage:normalize": "node scripts/normalize-coverage-lcov.mjs",
        "docs:build": "npm --workspace docusaurus run build",
        "docs:start": "npm --workspace docusaurus start",
        "docs:typecheck": "npm --workspace docusaurus run typecheck",
        "format": "npm run prettier:fix",
        "format:check": "npm run prettier",
        "lint": "npm run lint:root && npm run lint:electron-app && npm run lint:docusaurus",
        "lint:all": "npm run lint",
        "lint:all:fix": "npm run lint:fix",
        "lint:css": "stylelint \"electron-app/**/*.css\" --config stylelint.config.mjs --quiet",
        "lint:css:fix": "stylelint \"electron-app/**/*.css\" --config stylelint.config.mjs --fix",
        "lint:docusaurus": "npm --workspace docusaurus run lint",
        "lint:docusaurus:content": "npm --workspace docusaurus run lint:content",
        "lint:docusaurus:fix": "npm --workspace docusaurus run lint:fix",
        "lint:electron-app": "eslint --config eslint.config.mjs --quiet --cache --cache-strategy content --cache-location .cache/.eslintcache-electron electron-app && npm --workspace electron-app run typecheck",
        "lint:electron-app:fix": "eslint --config eslint.config.mjs --quiet --cache --cache-strategy content --cache-location .cache/.eslintcache-electron --fix electron-app && npm --workspace electron-app run typecheck",
        "lint:fix": "npm run lint:root:fix && npm run lint:electron-app:fix && npm run lint:docusaurus:fix",
        "lint:root": "npx eslint --cache --cache-strategy content --cache-location .cache/.eslintcache-root . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "lint:root:check": "npx eslint --cache --cache-strategy content --cache-location .cache/.eslintcache-root . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "lint:root:fix": "npx eslint --cache --cache-strategy content --cache-location .cache/.eslintcache-root --fix . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "package": "npm --workspace electron-app run package",
        "prettier": "prettier package.json electron-app/package.json docusaurus/package.json prettier.config.mjs stylelint.config.mjs .remarkrc.mjs eslint.config.mjs playwright.config.ts vite.renderer.config.mjs vitest.config.ts tsconfig.vitest-typecheck.json tsconfig.electron-app.eslint.json --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "prettier:fix": "prettier package.json electron-app/package.json docusaurus/package.json prettier.config.mjs stylelint.config.mjs .remarkrc.mjs eslint.config.mjs playwright.config.ts vite.renderer.config.mjs vitest.config.ts tsconfig.vitest-typecheck.json tsconfig.electron-app.eslint.json --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "start": "npm --workspace electron-app start",
        "start:prod": "npm --workspace electron-app run start-prod",
        "start-prod": "npm run start:prod",
        "pretest": "npm run build:runtime-ts",
        "test": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --run --reporter=dot --silent --maxWorkers 1",
        "test:changed": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:ci": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --run --coverage --reporter=dot --silent --maxWorkers 1",
        "test:coverage": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --coverage --run --reporter=dot --silent --maxWorkers 1",
        "test:coverage:changed": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --coverage --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:coverage-changed": "npm run test:coverage:changed",
        "test:e2e": "npm run test:playwright",
        "test:integration": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --run tests/integration --maxWorkers 1",
        "test:playwright": "npm run build:runtime-ts && playwright test --config playwright.config.ts",
        "test:tabs": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --run --reporter=verbose tests/unit/tabs --maxWorkers 1",
        "test:unit": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --run tests/unit --maxWorkers 1",
        "test:watch": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --watch",
        "test:watch:changed": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs --config vitest.config.ts --watch --changed",
        "test:watch-changed": "npm run test:watch:changed",
        "typecheck": "npm --workspace electron-app run typecheck",
        "types:build": "npm --workspace electron-app run types:build",
        "update-changelog": "npm run changelog",
        "update-changelog:all": "npm run changelog:all",
        "update-changelog:latest": "npm run changelog",
        "update-deps": "npx npm-check-updates -i --workspaces --root --install never && npm install"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/jsdom": "^28.0.3",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "cross-env": "^10.1.0",
        "electron": "^42.2.0",
        "electron-builder": "^26.8.1",
        "electron-builder-squirrel-windows": "^26.8.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.0",
        "eslint-config-nick2bad4u": "^1.1.0",
        "eslint-plugin-depend": "^1.5.0",
        "fast-check": "^4.8.0",
        "git-cliff": "^2.13.1",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "makensis": "^3.0.5",
        "prettier": "^3.8.3",
        "prettier-config-nick2bad4u": "^1.0.13",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.0.2",
        "remark-lint-check-toc": "^1.0.0",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.0.5",
        "stylelint": "^17.12.0",
        "stylelint-config-nick2bad4u": "^1.0.12",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "packageManager": "npm@11.15.0",
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=7.0.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "npm",
            "version": ">=7.0.0",
            "onFail": "warn"
        },
        "runtime": {
            "name": "node",
            "onFail": "warn",
            "version": ">=16.0.0"
        }
    }
}
