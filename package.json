{
    "name": "fitfileviewer-root",
    "private": true,
    "description": "Root workspace tooling for FitFileViewer.",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com>",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "main": "package.json",
    "workspaces": [
        "electron-app",
        "docusaurus"
    ],
    "scripts": {
        "build": "node scripts/build-package.mjs",
        "build:all": "node scripts/build-package.mjs -mwl",
        "build:dev": "node scripts/build-package.mjs --node-env development",
        "build:dev:all": "node scripts/build-package.mjs --node-env development -l",
        "build:dev:package": "node scripts/build-package.mjs --node-env development --dir",
        "build:dev:package:all": "node scripts/build-package.mjs --node-env development -l --dir",
        "build:dev:package:prod": "node scripts/build-package.mjs --node-env production --dir",
        "build:dev:package:prod:all": "node scripts/build-package.mjs --node-env production -l --dir",
        "build:dev:package:prod:all:zip": "node scripts/build-package.mjs --node-env production -l --dir --win --x64 --ia32 --mac --linux --zip",
        "build:flatpak": "npm run build:runtime-ts && node scripts/build-flatpak.mjs",
        "build:macos-deps": "node scripts/ensure-macos-builder-deps.mjs",
        "build:prod": "node scripts/build-package.mjs --node-env production",
        "build:renderer": "node scripts/build-renderer.mjs",
        "build:runtime-ts": "node scripts/build-runtime.mjs",
        "build:win7": "node scripts/build-win7.mjs",
        "changelog": "node scripts/generate-changelog.mjs",
        "clean:workspace": "node scripts/clean-workspace.mjs",
        "clean-releases": "node scripts/clean-releases.mjs",
        "clean-releases:1": "node scripts/clean-releases.mjs --delete-tags --keep-last 1",
        "clean-releases:10": "node scripts/clean-releases.mjs --delete-tags --keep-last 10",
        "clean-releases:2": "node scripts/clean-releases.mjs --delete-tags --keep-last 2",
        "clean-releases:3": "node scripts/clean-releases.mjs --delete-tags --keep-last 3",
        "clean-releases:4": "node scripts/clean-releases.mjs --delete-tags --keep-last 4",
        "clean-releases:5": "node scripts/clean-releases.mjs --delete-tags --keep-last 5",
        "clean-releases:6": "node scripts/clean-releases.mjs --delete-tags --keep-last 6",
        "clean-releases:7": "node scripts/clean-releases.mjs --delete-tags --keep-last 7",
        "clean-releases:8": "node scripts/clean-releases.mjs --delete-tags --keep-last 8",
        "clean-releases:9": "node scripts/clean-releases.mjs --delete-tags --keep-last 9",
        "clean-releases:all": "node scripts/clean-releases.mjs --delete-tags --keep-last 1000",
        "clean-releases:tags": "node scripts/clean-releases.mjs --delete-tags",
        "coverage:analyze": "node scripts/analyze-coverage.mjs",
        "coverage:normalize": "node scripts/normalize-coverage-lcov.mjs",
        "docs:build": "node scripts/build-docs.mjs",
        "docs:clear": "node scripts/run-docusaurus.mjs clear",
        "docs:deploy": "node scripts/run-docusaurus.mjs deploy",
        "docs:serve": "node scripts/run-docusaurus.mjs serve",
        "docs:start": "node scripts/run-docusaurus.mjs start",
        "docs:typecheck": "node scripts/typecheck-docusaurus.mjs",
        "docs:typedoc": "node scripts/build-docs.mjs --typedoc-only",
        "format": "npm run prettier:fix",
        "hash:distributables": "node scripts/print-distributable-hashes.mjs",
        "lint": "npm run lint:root && npm run lint:electron-app && npm run lint:docusaurus",
        "lint:css": "node scripts/lint-css.mjs --quiet",
        "lint:css:fix": "node scripts/lint-css.mjs --fix",
        "lint:docusaurus": "node scripts/lint-docusaurus.mjs && node scripts/lint-docusaurus-content.mjs",
        "lint:docusaurus:content": "node scripts/lint-docusaurus-content.mjs",
        "lint:docusaurus:fix": "node scripts/lint-docusaurus.mjs --fix && node scripts/lint-docusaurus-content.mjs",
        "lint:electron-app": "node scripts/lint-electron-app.mjs",
        "lint:electron-app:fix": "node scripts/lint-electron-app.mjs --fix",
        "lint:fix": "npm run lint:root:fix && npm run lint:electron-app:fix && npm run lint:docusaurus:fix",
        "lint:root": "node scripts/lint-root.mjs",
        "lint:root:fix": "node scripts/lint-root.mjs --fix",
        "package": "node scripts/build-package.mjs --dir",
        "prettier": "node scripts/run-prettier.mjs --check",
        "prettier:fix": "node scripts/run-prettier.mjs --write",
        "release:bump-version": "node scripts/bump-app-version.mjs",
        "release:fix-latest-yml-sha512": "node scripts/fix-latest-yml-sha512.mjs",
        "release:list-release-dist-files": "node scripts/list-release-dist-files.mjs",
        "release:notes": "node scripts/generate-release-notes.mjs",
        "release:organize-distributables": "node scripts/organize-distributables.mjs",
        "release:publish-version": "node scripts/publish-app-version.mjs",
        "release:rename-squirrel-win32-assets": "node scripts/rename-squirrel-win32-release-assets.mjs",
        "release:rename-windows-latest-yml": "node scripts/rename-windows-latest-yml.mjs",
        "start": "node scripts/start-electron.mjs --inspect=9229 --remote-debugging-port=9222 electron-app",
        "start:prod": "node scripts/start-electron.mjs --electron-is-dev 0 electron-app",
        "pretest": "npm run build:runtime-ts",
        "test": "node scripts/run-vitest.mjs --run --reporter=dot --silent --maxWorkers 1",
        "test:changed": "node scripts/run-vitest.mjs --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:ci": "node scripts/run-vitest.mjs --run --coverage --reporter=dot --silent --maxWorkers 1",
        "test:coverage": "node scripts/run-vitest.mjs --coverage --run --reporter=dot --silent --maxWorkers 1",
        "test:coverage:changed": "node scripts/run-vitest.mjs --coverage --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:integration": "node scripts/run-vitest.mjs --run electron-app/tests/integration --maxWorkers 1",
        "test:playwright": "node scripts/run-playwright.mjs",
        "test:tabs": "node scripts/run-vitest.mjs --run --reporter=verbose electron-app/tests/unit/tabs --maxWorkers 1",
        "test:ui": "node scripts/run-vitest.mjs --ui",
        "test:unit": "node scripts/run-vitest.mjs --run electron-app/tests/unit --maxWorkers 1",
        "test:watch": "node scripts/run-vitest.mjs --watch",
        "test:watch:changed": "node scripts/run-vitest.mjs --watch --changed",
        "typecheck": "node scripts/run-typescript.mjs typecheck",
        "types:build": "node scripts/run-typescript.mjs declarations",
        "update-deps": "node scripts/update-deps.mjs"
    },
    "devDependencies": {
        "@docusaurus/tsconfig": "^3.9.2",
        "@maplibre/maplibre-gl-leaflet": "^0.1.3",
        "@playwright/test": "^1.60.0",
        "@types/hammerjs": "^2.0.46",
        "@types/jquery": "^4.0.0",
        "@types/jsdom": "^28.0.3",
        "@types/leaflet": "~1.9.21",
        "@types/leaflet-draw": "~1.0.13",
        "@types/leaflet.markercluster": "~1.5.6",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "arquero": "^8.0.3",
        "chart.js": "^4.5.1",
        "chartjs-adapter-date-fns": "^3.0.0",
        "chartjs-plugin-zoom": "^2.2.0",
        "datatables.net-dt": "^2.3.8",
        "date-fns": "^4.3.0",
        "dompurify": "^3.4.5",
        "electron": "^42.2.0",
        "electron-builder": "^26.8.1",
        "electron-builder-squirrel-windows": "^26.8.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.0",
        "eslint-config-nick2bad4u": "^1.1.0",
        "fast-check": "^4.8.0",
        "fast-xml-parser": "^5.8.0",
        "git-cliff": "^2.13.1",
        "globals": "^17.6.0",
        "hammerjs": "^2.0.8",
        "jquery": "^4.0.0",
        "jsdom": "^29.1.1",
        "jszip": "^3.10.1",
        "leaflet": "^1.9.4",
        "leaflet-draw": "^1.0.4",
        "leaflet-measure": "^3.1.0",
        "leaflet-minimap": "^3.6.1",
        "leaflet.fullscreen": "^5.3.1",
        "leaflet.locatecontrol": "^0.90.0",
        "leaflet.markercluster": "^1.5.3",
        "makensis": "^3.0.5",
        "maplibre-gl": "^5.24.0",
        "markdownlint-cli2": "^0.20.0",
        "npm-check-updates": "^22.2.1",
        "prettier": "^3.8.3",
        "prettier-config-nick2bad4u": "^1.0.13",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.0.2",
        "remark-lint-check-toc": "^1.0.0",
        "screenfull": "^6.0.2",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.0.5",
        "stylelint": "^17.12.0",
        "stylelint-config-nick2bad4u": "^1.0.12",
        "typedoc": "^0.28.16",
        "typedoc-plugin-markdown": "^4.10.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "packageManager": "npm@11.15.0",
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=7.0.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "npm",
            "version": ">=7.0.0",
            "onFail": "warn"
        },
        "runtime": {
            "name": "node",
            "onFail": "warn",
            "version": ">=16.0.0"
        }
    }
}
