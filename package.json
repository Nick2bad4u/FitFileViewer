{
    "name": "fitfileviewer-root",
    "private": true,
    "description": "Root workspace tooling for FitFileViewer.",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com>",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "main": "package.json",
    "workspaces": [
        "electron-app",
        "docusaurus"
    ],
    "scripts": {
        "build": "npm run build:runtime-ts && electron-builder --projectDir electron-app --config ../electron-builder.config.cjs",
        "build:all": "npm run build:runtime-ts && electron-builder --projectDir electron-app --config ../electron-builder.config.cjs -mwl",
        "build:dev": "npm run build:runtime-ts && cross-env NODE_ENV=development electron-builder --projectDir electron-app --config ../electron-builder.config.cjs",
        "build:dev:all": "npm run build:runtime-ts && cross-env NODE_ENV=development electron-builder --projectDir electron-app --config ../electron-builder.config.cjs -l",
        "build:dev:package": "npm run build:runtime-ts && cross-env NODE_ENV=development electron-builder --projectDir electron-app --config ../electron-builder.config.cjs --dir",
        "build:dev:package:all": "npm run build:runtime-ts && cross-env NODE_ENV=development electron-builder --projectDir electron-app --config ../electron-builder.config.cjs -l --dir",
        "build:dev:package:prod": "npm run build:runtime-ts && cross-env NODE_ENV=production electron-builder --projectDir electron-app --config ../electron-builder.config.cjs --dir",
        "build:dev:package:prod:all": "npm run build:runtime-ts && cross-env NODE_ENV=production electron-builder --projectDir electron-app --config ../electron-builder.config.cjs -l --dir",
        "build:dev:package:prod:all:zip": "npm run build:runtime-ts && cross-env NODE_ENV=production electron-builder --projectDir electron-app --config ../electron-builder.config.cjs -l --dir --win --x64 --ia32 --mac --linux --zip",
        "build:flatpak": "npm run build:runtime-ts && node scripts/build-flatpak.mjs",
        "build:prod": "npm run build:runtime-ts && cross-env NODE_ENV=production electron-builder --projectDir electron-app --config ../electron-builder.config.cjs",
        "build:renderer": "vite build --config vite.renderer.config.mjs",
        "build:runtime-ts": "node scripts/clean-runtime-dist.mjs && tsc --project tsconfig.runtime.json && node scripts/bundle-preload.mjs && npm run build:renderer && node scripts/format-runtime-output.mjs && node scripts/prepare-runtime-dist.mjs",
        "build:win7": "node scripts/build-win7.mjs",
        "changelog": "git-cliff --config cliff.toml --output CHANGELOG.md",
        "clean:workspace": "node scripts/clean-workspace.mjs",
        "clean-releases": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1",
        "clean-releases:1": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 1",
        "clean-releases:10": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 10",
        "clean-releases:2": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 2",
        "clean-releases:3": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 3",
        "clean-releases:4": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 4",
        "clean-releases:5": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 5",
        "clean-releases:6": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 6",
        "clean-releases:7": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 7",
        "clean-releases:8": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 8",
        "clean-releases:9": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 9",
        "clean-releases:all": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags -keepLast 1000",
        "clean-releases:tags": "powershell -ExecutionPolicy Bypass -File ./.github/Clean-Releases.ps1 -deleteTags",
        "coverage:analyze": "node scripts/analyze-coverage.mjs",
        "coverage:normalize": "node scripts/normalize-coverage-lcov.mjs",
        "docs:build": "npm --workspace docusaurus run build",
        "docs:start": "npm --workspace docusaurus start",
        "docs:typecheck": "npm --workspace docusaurus run typecheck",
        "format": "npm run prettier:fix",
        "lint": "npm run lint:root && npm run lint:electron-app && npm run lint:docusaurus",
        "lint:css": "stylelint \"electron-app/**/*.css\" --config stylelint.config.mjs --quiet",
        "lint:css:fix": "stylelint \"electron-app/**/*.css\" --config stylelint.config.mjs --fix",
        "lint:docusaurus": "npm --workspace docusaurus run lint",
        "lint:docusaurus:content": "npm --workspace docusaurus run lint:content",
        "lint:docusaurus:fix": "npm --workspace docusaurus run lint:fix",
        "lint:electron-app": "eslint --config eslint.config.mjs --quiet --cache --cache-strategy content --cache-location .cache/.eslintcache-electron electron-app && npm run typecheck",
        "lint:electron-app:fix": "eslint --config eslint.config.mjs --quiet --cache --cache-strategy content --cache-location .cache/.eslintcache-electron --fix electron-app && npm run typecheck",
        "lint:fix": "npm run lint:root:fix && npm run lint:electron-app:fix && npm run lint:docusaurus:fix",
        "lint:root": "npx eslint --cache --cache-strategy content --cache-location .cache/.eslintcache-root . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "lint:root:fix": "npx eslint --cache --cache-strategy content --cache-location .cache/.eslintcache-root --fix . --ignore-pattern \"electron-app/**\" --ignore-pattern \"docusaurus/**\"",
        "package": "npm run build:runtime-ts && electron-builder --projectDir electron-app --config ../electron-builder.config.cjs --dir",
        "prettier": "node scripts/run-prettier.mjs --check",
        "prettier:fix": "node scripts/run-prettier.mjs --write",
        "start": "npm run build:runtime-ts && electron --inspect=9229 --remote-debugging-port=9222 electron-app",
        "start:prod": "npm run build:runtime-ts && cross-env ELECTRON_IS_DEV=0 electron electron-app",
        "pretest": "npm run build:runtime-ts",
        "test": "node scripts/run-vitest.mjs --run --reporter=dot --silent --maxWorkers 1",
        "test:changed": "node scripts/run-vitest.mjs --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:ci": "node scripts/run-vitest.mjs --run --coverage --reporter=dot --silent --maxWorkers 1",
        "test:coverage": "node scripts/run-vitest.mjs --coverage --run --reporter=dot --silent --maxWorkers 1",
        "test:coverage:changed": "node scripts/run-vitest.mjs --coverage --changed --run --reporter=dot --silent --maxWorkers 1",
        "test:integration": "node scripts/run-vitest.mjs --run electron-app/tests/integration --maxWorkers 1",
        "test:playwright": "npm run build:runtime-ts && playwright test --config playwright.config.ts",
        "test:tabs": "node scripts/run-vitest.mjs --run --reporter=verbose electron-app/tests/unit/tabs --maxWorkers 1",
        "test:unit": "node scripts/run-vitest.mjs --run electron-app/tests/unit --maxWorkers 1",
        "test:watch": "node scripts/run-vitest.mjs --watch",
        "test:watch:changed": "node scripts/run-vitest.mjs --watch --changed",
        "typecheck": "tsc --project tsconfig.electron-app.json --noEmit",
        "types:build": "tsc --project tsconfig.electron-app.json --declaration --emitDeclarationOnly --declarationMap false --outDir ./electron-app/types",
        "update-deps": "npx npm-check-updates -i --workspaces --root --install never && npm install"
    },
    "devDependencies": {
        "@maplibre/maplibre-gl-leaflet": "^0.1.3",
        "@playwright/test": "^1.60.0",
        "@types/hammerjs": "^2.0.46",
        "@types/jquery": "^4.0.0",
        "@types/jsdom": "^28.0.3",
        "@types/leaflet": "~1.9.21",
        "@types/leaflet-draw": "~1.0.13",
        "@types/leaflet.markercluster": "~1.5.6",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "arquero": "^8.0.3",
        "chart.js": "^4.5.1",
        "chartjs-adapter-date-fns": "^3.0.0",
        "chartjs-plugin-zoom": "^2.2.0",
        "cross-env": "^10.1.0",
        "datatables.net-dt": "^2.3.8",
        "date-fns": "^4.3.0",
        "dompurify": "^3.4.5",
        "electron": "^42.2.0",
        "electron-builder": "^26.8.1",
        "electron-builder-squirrel-windows": "^26.8.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.0",
        "eslint-config-nick2bad4u": "^1.1.0",
        "eslint-plugin-depend": "^1.5.0",
        "fast-check": "^4.8.0",
        "fast-xml-parser": "^5.8.0",
        "git-cliff": "^2.13.1",
        "globals": "^17.6.0",
        "hammerjs": "^2.0.8",
        "jquery": "^4.0.0",
        "jsdom": "^29.1.1",
        "jszip": "^3.10.1",
        "leaflet": "^1.9.4",
        "leaflet-draw": "^1.0.4",
        "leaflet-measure": "^3.1.0",
        "leaflet-minimap": "^3.6.1",
        "leaflet.fullscreen": "^5.3.1",
        "leaflet.locatecontrol": "^0.90.0",
        "leaflet.markercluster": "^1.5.3",
        "makensis": "^3.0.5",
        "maplibre-gl": "^5.24.0",
        "prettier": "^3.8.3",
        "prettier-config-nick2bad4u": "^1.0.13",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.0.2",
        "remark-lint-check-toc": "^1.0.0",
        "screenfull": "^6.0.2",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.0.5",
        "stylelint": "^17.12.0",
        "stylelint-config-nick2bad4u": "^1.0.12",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "packageManager": "npm@11.15.0",
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=7.0.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "npm",
            "version": ">=7.0.0",
            "onFail": "warn"
        },
        "runtime": {
            "name": "node",
            "onFail": "warn",
            "version": ">=16.0.0"
        }
    }
}
