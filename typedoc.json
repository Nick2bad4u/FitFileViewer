{
    "$schema": "https://typedoc.org/schema.json",
    "categoryOrder": [
        "UI Components",
        "Visualization",
        "Maps",
        "Charts",
        "Tables",
        "Data Processing",
        "Formatting",
        "State Management",
        "File Operations",
        "Utilities",
        "Constants",
        "*"
    ],
    "compilerOptions": {
        "noErrorTruncation": false,
        "skipDefaultLibCheck": true,
        "skipLibCheck": true
    },
    "entryPointStrategy": "expand",
    "entryPoints": [
        "electron-app/**/*.{ts,mts,cts,tsx,js,jsx}"
    ],
    "exclude": [
        "**/dist/**",
        "**/node_modules/**",
        "**/coverage/**",
        "**/build/**",
        "**/out/**",
        "**/tmp/**",
        "**/test/**",
        "**/tests/**",
        "**/spec/**",
        "**/specs/**",
        "**/examples/**",
        "**/*.test.*",
        "**/*.spec.*",
        "**/mock*",
        "**/test-*",
        "**/setupTests*",
        "**/types/**",
        "**/*.d.ts",
        "**/html/**",
        "**/assets/**",
        "**/utils/files/export/gpxExport.js"
    ],
    "extends": [
        "typedoc-config-nick2bad4u/typedoc.json"
    ],
    "externalSymbolLinkMappings": {
        "chart.js": {
            "Chart": "https://www.chartjs.org/docs/latest/getting-started/"
        },
        "electron": {
            "BrowserWindow": "https://www.electronjs.org/docs/latest/api/browser-window",
            "Menu": "https://www.electronjs.org/docs/latest/api/menu",
            "app": "https://www.electronjs.org/docs/latest/api/app",
            "dialog": "https://www.electronjs.org/docs/latest/api/dialog",
            "ipcMain": "https://www.electronjs.org/docs/latest/api/ipc-main",
            "ipcRenderer": "https://www.electronjs.org/docs/latest/api/ipc-renderer"
        },
        "leaflet": {
            "L": "https://leafletjs.com/reference.html",
            "Map": "https://leafletjs.com/reference.html#map"
        }
    },
    "gitRevision": "main",
    "githubPages": true,
    "hideGenerator": false,
    "intentionallyNotExported": ["ZoneData"],
    "name": "FitFileViewer - API Documentation",
    "out": "docusaurus/docs/api",
    "pretty": true,
    "searchInComments": true,
    "tsconfig": "tsconfig.app.json"
}
