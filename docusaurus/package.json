{
    "name": "fitfileviewer-docs",
    "version": "1.0.0",
    "private": true,
    "description": "Documentation website for FitFileViewer - Cross-platform .fit file viewer and analyzer",
    "scripts": {
        "build": "node ../scripts/build-docs.mjs",
        "build:local": "node ../scripts/build-docs.mjs",
        "clear": "node ../scripts/run-docusaurus.mjs clear",
        "deploy": "node ../scripts/run-docusaurus.mjs deploy",
        "docs:typedoc": "node ../scripts/build-docs.mjs --typedoc-only",
        "docs:typedoc:local": "npm run docs:typedoc",
        "docusaurus": "node ../scripts/run-docusaurus.mjs",
        "lint": "npm run lint:code && npm run lint:content",
        "lint:code": "node ../scripts/lint-docusaurus.mjs",
        "lint:code:check": "node ../scripts/lint-docusaurus.mjs",
        "lint:code:fix": "node ../scripts/lint-docusaurus.mjs --fix",
        "lint:content": "node ../scripts/lint-docusaurus-content.mjs",
        "lint:fix": "npm run lint:code:fix && npm run lint:content",
        "serve": "node ../scripts/run-docusaurus.mjs serve",
        "start": "node ../scripts/run-docusaurus.mjs start",
        "swizzle": "node ../scripts/run-docusaurus.mjs swizzle",
        "typecheck": "node ../scripts/typecheck-docusaurus.mjs",
        "write-heading-ids": "node ../scripts/run-docusaurus.mjs write-heading-ids",
        "write-translations": "node ../scripts/run-docusaurus.mjs write-translations"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    },
    "dependencies": {
        "@docusaurus/core": "^3.9.2",
        "@docusaurus/preset-classic": "^3.9.2",
        "@docusaurus/theme-live-codeblock": "^3.9.2",
        "@docusaurus/theme-mermaid": "^3.9.2",
        "@easyops-cn/docusaurus-search-local": "^0.53.0",
        "@mdx-js/react": "^3.1.1",
        "docusaurus-plugin-copy-page-button": "^0.3.5",
        "docusaurus-plugin-image-zoom": "^3.0.1",
        "docusaurus-plugin-llms": "^0.2.2",
        "docusaurus-plugin-typedoc": "^1.4.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@docusaurus/eslint-plugin": "^3.9.2",
        "@docusaurus/module-type-aliases": "^3.9.2",
        "@docusaurus/tsconfig": "^3.9.2",
        "@docusaurus/types": "^3.9.2",
        "@types/node": "^25.2.2",
        "@types/react": "^19.2.13",
        "@types/react-dom": "^19.2.3",
        "clsx": "^2.1.1",
        "markdownlint-cli2": "^0.20.0",
        "prism-react-renderer": "^2.4.1",
        "typedoc": "^0.28.16",
        "typedoc-docusaurus-theme": "^1.4.2",
        "typedoc-plugin-coverage": "^4.0.2",
        "typedoc-plugin-dt-links": "^2.0.41",
        "typedoc-plugin-external-package-links": "^0.2.0",
        "typedoc-plugin-markdown": "^4.10.0",
        "typedoc-plugin-mdn-links": "^5.1.1",
        "typedoc-plugin-missing-exports": "^4.1.2",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-rename-defaults": "^0.7.3",
        "typedoc-plugin-replace-text": "^4.2.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18.0"
    }
}
