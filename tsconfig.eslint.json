{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2024"
    },
    "exclude": [
        "docusaurus/**",
        "electron-app/**",
        "node_modules/**"
    ],
    "include": [
        ".*.mjs",
        "*.js",
        "*.mjs",
        ".github/**/*.js",
        "utils/**/*.js"
    ]
}
